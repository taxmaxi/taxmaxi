{
  "name": "@my/sync-engine",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist/**"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "default": "./dist/services/index.js"
    },
    "./layers": {
      "types": "./dist/layers/index.d.ts",
      "default": "./dist/layers/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "default": "./dist/shared/index.js"
    },
    "./services/SourceSyncService": {
      "types": "./dist/services/SourceSyncService.d.ts",
      "default": "./dist/services/SourceSyncService.js"
    },
    "./providers/coinbase": {
      "types": "./dist/providers/coinbase/index.d.ts",
      "default": "./dist/providers/coinbase/index.js"
    },
    "./providers/coinbase/layers": {
      "types": "./dist/providers/coinbase/layers/index.d.ts",
      "default": "./dist/providers/coinbase/layers/index.js"
    },
    "./providers/coinbase/services": {
      "types": "./dist/providers/coinbase/services/index.d.ts",
      "default": "./dist/providers/coinbase/services/index.js"
    },
    "./providers/coinbase/services/CoinbaseSyncClient": {
      "types": "./dist/providers/coinbase/services/CoinbaseSyncClient.d.ts",
      "default": "./dist/providers/coinbase/services/CoinbaseSyncClient.js"
    },
    "./providers/coinbase/services/CoinbaseReferenceDataService": {
      "types": "./dist/providers/coinbase/services/CoinbaseReferenceDataService.d.ts",
      "default": "./dist/providers/coinbase/services/CoinbaseReferenceDataService.js"
    },
    "./providers/coinbase/services/CoinbaseReferenceMappingService": {
      "types": "./dist/providers/coinbase/services/CoinbaseReferenceMappingService.d.ts",
      "default": "./dist/providers/coinbase/services/CoinbaseReferenceMappingService.js"
    },
    "./providers/coinbase/services/CoinbaseRecordNormalizer": {
      "types": "./dist/providers/coinbase/services/CoinbaseRecordNormalizer.d.ts",
      "default": "./dist/providers/coinbase/services/CoinbaseRecordNormalizer.js"
    },
    "./providers/coinbase/services/CoinbaseSourceSyncProvider": {
      "types": "./dist/providers/coinbase/services/CoinbaseSourceSyncProvider.d.ts",
      "default": "./dist/providers/coinbase/services/CoinbaseSourceSyncProvider.js"
    },
    "./providers/coinbase/services/CoinbaseCredentialRepository": {
      "types": "./dist/providers/coinbase/services/CoinbaseCredentialRepository.d.ts",
      "default": "./dist/providers/coinbase/services/CoinbaseCredentialRepository.js"
    },
    "./providers/coinbase/services/CoinbaseLegDerivationService": {
      "types": "./dist/providers/coinbase/services/CoinbaseLegDerivationService.d.ts",
      "default": "./dist/providers/coinbase/services/CoinbaseLegDerivationService.js"
    },
    "./providers/helius-solana": {
      "types": "./dist/providers/helius-solana/index.d.ts",
      "default": "./dist/providers/helius-solana/index.js"
    },
    "./providers/helius-solana/layers": {
      "types": "./dist/providers/helius-solana/layers/index.d.ts",
      "default": "./dist/providers/helius-solana/layers/index.js"
    },
    "./providers/helius-solana/services": {
      "types": "./dist/providers/helius-solana/services/index.d.ts",
      "default": "./dist/providers/helius-solana/services/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "type-check": "tsc --noEmit",
    "type-check:tests": "tsc -p tsconfig.tests.json",
    "clean": "rm -rf dist .turbo node_modules && rm -f tsconfig.tsbuildinfo && rm -f tsconfig.tests.tsbuildinfo"
  },
  "dependencies": {
    "@effect/platform": "0.96.1",
    "@my/core": "workspace:*",
    "effect": "3.21.2",
    "helius-sdk": "2.2.2"
  },
  "devDependencies": {
    "@effect/sql": "0.51.1",
    "@effect/sql-pg": "0.52.1",
    "@my/typescript-config": "workspace:*",
    "@types/node": "26.0.1",
    "drizzle-orm": "1.0.0-beta.13-f728631",
    "typescript": "6.0.3"
  }
}
