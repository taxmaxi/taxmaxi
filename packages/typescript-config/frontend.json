{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Frontend",
  "extends": "./base.json",
  "compilerOptions": {
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "jsx": "react-jsx",
    "noEmit": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "forceConsistentCasingInFileNames": true
  }
}
