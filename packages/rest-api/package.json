{
  "name": "@my/rest-api",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist/**"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts.d.ts",
      "default": "./dist/contracts.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "type-check": "tsc --noEmit",
    "type-check:tests": "tsc -p tsconfig.tests.json",
    "clean": "rm -rf dist .turbo node_modules && rm -f tsconfig.tsbuildinfo && rm -f tsconfig.tests.tsbuildinfo"
  },
  "dependencies": {
    "@effect/platform": "0.96.1",
    "@effect/platform-node": "0.106.0",
    "@my/core": "workspace:*",
    "@my/persistence": "workspace:*",
    "@my/sync-engine": "workspace:*",
    "@x402/core": "2.12.0",
    "@x402/evm": "2.12.0",
    "@x402/extensions": "2.12.0",
    "@x402/svm": "2.12.0",
    "effect": "3.21.2"
  },
  "devDependencies": {
    "@effect/vitest": "~0.29.0",
    "@my/typescript-config": "workspace:*",
    "@types/node": "~25.5.0",
    "typescript": "~6.0.2"
  }
}
