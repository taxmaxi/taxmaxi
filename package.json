{
  "name": "taxmaxi.com",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "prepare": "effect-language-service patch && husky",
    "generate": "plop",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "build": "turbo build",
    "clean": "turbo run clean && rm -rf node_modules .turbo && rm -f pnpm-lock.yaml",
    "clean:lite": "turbo run clean && rm -rf .turbo",
    "clean:tsbuildinfo": "find . -name 'tsconfig.tsbuildinfo' -type f -delete",
    "db:generate": "pnpm --filter @my/persistence run migration:generate",
    "db:migrate": "pnpm --filter @my/persistence run migration:run",
    "db:seed": "pnpm --filter @my/persistence run seed",
    "lint": "oxlint -c .oxlintrc.json apps packages plopfile.cjs",
    "lint:fix": "oxlint -c .oxlintrc.json --fix apps packages plopfile.cjs",
    "format": "oxfmt -c .oxfmtrc.jsonc --check apps packages package.json pnpm-workspace.yaml turbo.json .oxfmtrc.jsonc .oxlintrc.json AGENTS.md",
    "format:fix": "oxfmt -c .oxfmtrc.jsonc apps packages package.json pnpm-workspace.yaml turbo.json .oxfmtrc.jsonc .oxlintrc.json AGENTS.md",
    "type-check": "turbo run type-check",
    "type-check:tests": "turbo run type-check:tests",
    "server:build": "turbo run build --filter=server...",
    "server:dev": "turbo run dev --filter=server...",
    "worker:build": "turbo run build --filter=worker...",
    "worker:dev": "turbo run dev --filter=worker..."
  },
  "devDependencies": {
    "@effect/language-service": "~0.85.1",
    "@vitest/coverage-v8": "~4.1.2",
    "husky": "~9.1.7",
    "lint-staged": "~16.4.0",
    "oxfmt": "~0.54.0",
    "oxlint": "~1.69.0",
    "oxlint-tsgolint": "~0.23.0",
    "plop": "~4.0.5",
    "turbo": "~2.9.16",
    "typescript": "~6.0.2",
    "vite": "~8.0.3",
    "vitest": "~4.1.2"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,vue,astro,svelte}": "oxlint -c .oxlintrc.json",
    "**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,toml,json,jsonc,yaml,yml,html,vue,css,scss,less,gql,graphql,md,mdx}": "oxfmt -c .oxfmtrc.jsonc --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@11.5.2"
}
