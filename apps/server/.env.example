PGUSER="postgres"
PGPASSWORD="postgres"
PGHOST="localhost"
PGPORT="5432"
PGDATABASE="taxmaxi"

# Optional: Use this instead of PGHOST/PGPORT/PGUSER/PGPASSWORD/PGDATABASE
# DATABASE_URL="postgres://postgres:postgres@localhost:5432/taxmaxi"

# Optional Postgres pool tuning
PG_MAX_CONNECTIONS="10"
PG_IDLE_TIMEOUT="60 seconds"
PG_CONNECTION_TIMEOUT="10 seconds"

# Auth config
# Public origin of this API used for auth callbacks / redirects.
# Production: https://api.taxmaxi.com
AUTH_PUBLIC_BASE_URL="http://localhost:4000"
AUTH_ENABLED_PROVIDERS="local"
AUTH_DEFAULT_ROLE="member"
AUTH_SESSION_DURATION="24 hours"
AUTH_AUTO_LINK_BY_EMAIL="true"
AUTH_REQUIRE_EMAIL_VERIFICATION="false"

# Local auth policy (used by /register)
AUTH_LOCAL_REQUIRE_EMAIL_VERIFICATION="false"
AUTH_LOCAL_MIN_PASSWORD_LENGTH="8"
AUTH_LOCAL_REQUIRE_UPPERCASE="false"
AUTH_LOCAL_REQUIRE_NUMBERS="false"
AUTH_LOCAL_REQUIRE_SPECIAL_CHARS="false"
# "log" keeps verification local and writes the code to the api-server logs.
# "resend" sends real email via Resend.
AUTH_VERIFICATION_DELIVERY_MODE="log"

# Google OAuth config (required when AUTH_ENABLED_PROVIDERS includes "google")
AUTH_GOOGLE_CLIENT_ID=""
AUTH_GOOGLE_CLIENT_SECRET=""
AUTH_GOOGLE_REDIRECT_URI="http://localhost:4000/auth/callback/google"

# Coinbase OAuth config (required when AUTH_ENABLED_PROVIDERS includes "coinbase")
AUTH_COINBASE_CLIENT_ID=""
AUTH_COINBASE_CLIENT_SECRET=""
# TODO: change it once we can create new oauth clients on cdp again
AUTH_COINBASE_REDIRECT_URI="http://localhost:4000/cdp/callback" 

# Redis URL for the source sync queue.
QUEUE_REDIS_URL="redis://localhost:6379"

# development or production
ENVIRONMENT="development"
# Public origin of the frontend allowed by CORS.
# Production: https://www.taxmaxi.com
FRONTEND_URL="http://localhost:3000"

RESEND_API_KEY=""

SOLANA_RPC_URL=""

CLAIM_TOKEN_PEPPER=""

# Solana mainnet
# X402_ACCEPTED_NETWORKS=solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp
# Solana testnet
# X402_ACCEPTED_NETWORKS=solana:4uhcVJyU9pJkvQyS88uRDiswHXSCkY3z
# Solana devnet
X402_ACCEPTED_NETWORKS="solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1"
X402_FACILITATOR_URL="https://x402.org/facilitator"
X402_RECEIVING_WALLET_ADDRESS="<your-solana-devnet-wallet>"
X402_SOURCE_CREATION_PRICE="$1.00"

# Generate a high-entropy value with `openssl rand -base64 32`.
# Startup rejects blank, placeholder, and short values.
ANON_SESSION_SECRET="<generated-secret>"
