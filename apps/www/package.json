{
  "name": "www",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "deploy": "pnpm run build && wrangler deploy",
    "start": "vite preview",
    "cf-typegen": "wrangler types",
    "generate-routes": "tsr generate",
    "postinstall": "npm run cf-typegen && cd ../.. && pnpm run www:build-deps",
    "clean": "rm -rf .tanstack .turbo .wrangler dist node_modules"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "1.42.3",
    "@posthog/react": "1.10.3",
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/ai": "0.38.0",
    "@tanstack/ai-anthropic": "0.15.11",
    "@tanstack/ai-client": "0.19.0",
    "@tanstack/ai-gemini": "0.18.3",
    "@tanstack/ai-ollama": "0.8.11",
    "@tanstack/ai-openai": "0.15.9",
    "@tanstack/ai-react": "0.16.0",
    "@tanstack/react-devtools": "0.10.8",
    "@tanstack/react-form": "1.33.0",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-query-devtools": "5.101.2",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.26",
    "@tanstack/react-store": "0.11.0",
    "@tanstack/router-plugin": "1.168.18",
    "@tanstack/store": "0.11.0",
    "dotenv-cli": "11.0.0",
    "highlight.js": "11.11.1",
    "lucide-react": "1.22.0",
    "posthog-js": "1.396.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "streamdown": "2.5.0",
    "tailwindcss": "4.3.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "0.5.20",
    "@tanstack/devtools-event-client": "0.5.0",
    "@tanstack/devtools-vite": "0.8.1",
    "@tanstack/router-cli": "1.167.17",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
