# Required for behavior sampling unless SOLANA_RPC_URL points at another RPC endpoint.
HELIUS_API_KEY=""

# Required when running `crawler crawl solana --dune` with a positive `--top`.
DUNE_API_KEY=""

# Optional RPC override for behavior sampling. When set, HELIUS_API_KEY is optional.
SOLANA_RPC_URL=""

# Optional output directory used when `--out` is not passed.
CRAWLER_SOLANA_REFERENCE_DATA_DIR=""
