{
  "name": "worker",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "dotenv -- tsx watch --clear-screen=false src/index.ts",
    "type-check": "tsc --noEmit",
    "type-check:tests": "tsc -p tsconfig.tests.json",
    "clean": "rm -rf dist .turbo node_modules && rm -f tsconfig.tsbuildinfo && rm -f tsconfig.tests.tsbuildinfo"
  },
  "dependencies": {
    "@effect/platform-node": "0.106.0",
    "@my/core": "workspace:*",
    "@my/persistence": "workspace:*",
    "@my/sync-engine": "workspace:*",
    "bullmq": "5.76.4",
    "effect": "3.21.2",
    "ioredis": "5.10.1"
  },
  "devDependencies": {
    "@my/typescript-config": "workspace:*",
    "@types/node": "26.0.1",
    "dotenv-cli": "11.0.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
