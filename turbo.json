{
  "$schema": "https://v2-8-3.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "!*.tsbuildinfo"]
    },
    "clean": {
      "cache": false
    },
    "type-check": {
      "dependsOn": ["^type-check"]
    },
    "type-check:tests": {
      "dependsOn": ["^type-check:tests"]
    },
    "dev:tsc": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "cache": false,
      "dependsOn": ["//#lint", "build"],
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "//#quality": {
      "dependsOn": ["//#lint", "//#format"]
    },
    "//#quality:fix": {
      "dependsOn": ["//#lint:fix", "//#format:fix"],
      "cache": false
    },
    "//#format": {},
    "//#format:fix": {
      "dependsOn": ["//#lint:fix"],
      "cache": false
    },
    "//#lint": {},
    "//#lint:fix": {
      "cache": false
    }
  }
}
