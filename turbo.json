{
  "$schema": "https://v2-8-3.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "!*.tsbuildinfo"]
    },
    "clean": {
      "cache": false
    },
    "type-check": {
      "dependsOn": ["^type-check"]
    },
    "dev:tsc": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "cache": false,
      "dependsOn": ["lint", "build"],
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "format": {},
    "lint": {}
  }
}
